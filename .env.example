# Environment variables for Quantitative Trading System
# Copy this file to .env and update values as needed

# Database configuration
DATABASE_URL=sqlite:///data/market_data.db

# Data source configuration
YAHOO_FETCH_ENABLED=true
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
ALPHA_VANTAGE_ENABLED=false

# Risk management
MAX_POSITION_SIZE=0.1  # Maximum position size as fraction of portfolio
MAX_DRAWDOWN=0.2  # Maximum allowed drawdown
STOP_LOSS_PERCENT=0.05  # Stop loss percentage
TAKE_PROFIT_PERCENT=0.1  # Take profit percentage

# Backtesting
INITIAL_CAPITAL=100000.0
COMMISSION=0.001  # Commission rate per trade
SLIPPAGE=0.0001  # Slippage as fraction of price

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/quant_trading.log

# Visualization
PLOT_THEME=dark
PLOT_SAVE_FORMAT=png

# Performance optimization
USE_CACHE=true
CACHE_EXPIRY_DAYS=7